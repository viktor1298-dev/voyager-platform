{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // .tool_response.filePath' 2>/dev/null); [[ \"$FILE\" =~ \\.(ts|tsx|js|jsx|json)$ ]] && npx @biomejs/biome format --write \"$FILE\" 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "Formatting with Biome..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // .tool_response.filePath' 2>/dev/null); [[ \"$FILE\" =~ \\.(ts|tsx)$ ]] && (cd /Users/viktork/Documents/private/GitHub-private/voyager-platform && pnpm typecheck 2>&1 | tail -20) 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Type-checking..."
          }
        ]
      }
    ]
  }
}
