DATABASE_URL=postgresql://voyager:voyager_dev@localhost:5432/voyager_dev
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production
ADMIN_PASSWORD=admin123
# 32-byte hex key for AES-256-GCM credential encryption (generate with: openssl rand -hex 32)
CLUSTER_CRED_ENCRYPTION_KEY=  # Required: generate with `openssl rand -hex 32`
# Set to false to skip K8s watchers and background jobs (for local dev without a K8s cluster)
K8S_ENABLED=true
# Log level: fatal, error, warn, info, debug, trace (default: info)
LOG_LEVEL=debug
# Loki URL for centralized log collection (optional — logs ship to Loki when set)
LOKI_URL=http://localhost:3100
