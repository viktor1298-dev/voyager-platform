{
  "name": "@voyager/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/server.ts",
    "./types": "./src/routers/index.ts"
  },
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "build": "rm -rf dist && pnpm --filter @voyager/types build && pnpm --filter @voyager/db build && tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "start": "node dist/server.js",
    "test": "vitest run",
    "seed:admin": "tsx src/scripts/seed-admin.ts"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-sts": "^3.1019.0",
    "@aws-sdk/util-format-url": "^3.972.8",
    "@azure/arm-containerservice": "^25.0.0",
    "@azure/identity": "^4.13.1",
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.2.0",
    "@google-cloud/container": "^6.7.0",
    "@kubernetes/client-node": "^1.4.0",
    "@openfeature/core": "^1.9.2",
    "@openfeature/flagd-provider": "^0.14.0",
    "@openfeature/server-sdk": "^1.20.2",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sentry/node": "^10.46.0",
    "@sentry/profiling-node": "^10.46.0",
    "@smithy/protocol-http": "^5.3.12",
    "@smithy/signature-v4": "^5.3.12",
    "@trpc/server": "^11.15.1",
    "@voyager/config": "workspace:*",
    "@voyager/db": "workspace:*",
    "@voyager/types": "workspace:*",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.4",
    "redis": "^5.11.0",
    "trpc-to-openapi": "3.2.0",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
