{
  "name": "@voyager/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/server.ts",
    "./types": "./src/routers/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "rm -rf dist && pnpm --filter @voyager/types build && pnpm --filter @voyager/db build && tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "start": "node dist/server.js",
    "test": "vitest run",
    "seed:admin": "tsx src/scripts/seed-admin.ts"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@kubernetes/client-node": "^1.4.0",
    "@openfeature/flagd-provider": "^0.13.4",
    "@openfeature/server-sdk": "^1.20.1",
    "@opentelemetry/auto-instrumentations-node": "^0.69.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/resources": "^2.5.1",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@sentry/node": "^10.38.0",
    "@sentry/profiling-node": "^10.38.0",
    "@trpc/server": "^11.0.0",
    "@voyager/config": "workspace:*",
    "@voyager/db": "workspace:*",
    "@voyager/types": "workspace:*",
    "better-auth": "^1.4.18",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.2.0",
    "redis": "^5.10.0",
    "trpc-to-openapi": "3.1.0",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "esbuild": "^0.27.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
