# ============================================================
# Stage 1 — deps: install dependencies (cached when only code changes)
# ============================================================
FROM node:22-alpine AS deps
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY apps/web/package.json apps/web/
COPY apps/api/package.json apps/api/
COPY packages/config/package.json packages/config/
COPY packages/db/package.json packages/db/
COPY packages/types/package.json packages/types/
COPY packages/ui/package.json packages/ui/

RUN pnpm install --frozen-lockfile

# ============================================================
# Stage 2 — builder: build Next.js (standalone output)
# ============================================================
FROM deps AS builder
WORKDIR /app

COPY apps/web/ apps/web/
COPY apps/api/ apps/api/
COPY packages/ packages/

RUN pnpm --filter @voyager/web build

# ============================================================
# Stage 3 — runner: minimal production image
# ============================================================
FROM node:22-alpine AS runner
WORKDIR /app

RUN addgroup -g 1001 -S nodejs && adduser -S voyager -u 1001

# Next.js standalone output includes everything needed
COPY --from=builder /app/apps/web/public ./public
COPY --from=builder --chown=voyager:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=voyager:nodejs /app/apps/web/.next/static ./apps/web/.next/static

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

USER voyager
EXPOSE 3000

CMD ["node", "apps/web/server.js"]
