{
  "name": "voyager-platform",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:restart": "lsof -ti:4001 | xargs kill 2>/dev/null; lsof -ti:3000 | xargs kill 2>/dev/null; pkill -f 'turbo dev' 2>/dev/null; sleep 1; turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @voyager/db db:generate",
    "db:push": "pnpm --filter @voyager/db db:push",
    "db:migrate": "pnpm --filter @voyager/db db:migrate",
    "db:seed": "pnpm --filter @voyager/db db:seed",
    "test:e2e": "playwright test",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "test:visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
    "health:check": "tsx scripts/health-check.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.6.2",
  "pnpm": {
    "overrides": {
      "h3": "1.15.5",
      "esbuild": "^0.27.0"
    },
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "sharp"
    ]
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-sts": "^3.1019.0",
    "@aws-sdk/util-format-url": "^3.972.8",
    "@azure/arm-containerservice": "^25.0.0",
    "@azure/identity": "^4.13.1",
    "@google-cloud/container": "^6.7.0",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@smithy/protocol-http": "^5.3.12",
    "@smithy/signature-v4": "^5.3.12"
  }
}
