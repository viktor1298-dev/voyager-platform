{
  "name": "voyager-platform",
  "private": true,
  "scripts": {
    "predev": "pkill -f 'tsx watch.*server\\.ts' 2>/dev/null; pkill -f 'turbo dev' 2>/dev/null; pkill -f 'next dev.*port 3000' 2>/dev/null; lsof -ti:4001 | xargs kill 2>/dev/null; lsof -ti:3000 | xargs kill 2>/dev/null; sleep 1; echo '✓ Dev cleanup done'",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @voyager/db db:generate",
    "db:push": "pnpm --filter @voyager/db db:push",
    "db:migrate": "pnpm --filter @voyager/db db:migrate",
    "db:seed": "pnpm --filter @voyager/db db:seed",
    "test:e2e": "playwright test",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "test:visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
    "health:check": "tsx scripts/health-check.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.6.2",
  "pnpm": {
    "overrides": {
      "h3": "1.15.5",
      "esbuild": "^0.27.0"
    },
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "sharp"
    ]
  },
  "dependencies": {
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-tooltip": "^1.2.8"
  }
}
