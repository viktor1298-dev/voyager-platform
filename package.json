{
  "name": "voyager-platform",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @voyager/db db:generate",
    "db:push": "pnpm --filter @voyager/db db:push",
    "db:migrate": "pnpm --filter @voyager/db db:migrate"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.6.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "sharp"
    ]
  }
}