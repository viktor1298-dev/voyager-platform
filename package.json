{
  "name": "voyager-platform",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @voyager/db db:generate",
    "db:push": "pnpm --filter @voyager/db db:push",
    "db:migrate": "pnpm --filter @voyager/db db:migrate",
    "db:seed": "pnpm --filter @voyager/db db:seed",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.3",
    "turbo": "^2.8.8",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.6.2",
  "pnpm": {
    "overrides": {
      "h3": "1.15.5",
      "esbuild": "^0.25.0"
    },
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "sharp"
    ]
  }
}
